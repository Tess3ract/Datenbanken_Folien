% Arrow mit fazit
% Usage: \arrowFazit{<length of arrow in cm>}{<Fazit Text>}
\newcommand{\arrowFazit}[2]{%
\begin{tikzpicture}
    \draw[
        draw=Blue,
        line width=3mm,
        -{Triangle[length=6mm,width=6mm]}
    ]
    (0,0) -- (#1cm,0);

    \node[
        anchor=west,
        align=left,
        text width=6cm
    ]
    at ([xshift=0.2cm]#1cm,0)
    {#2};
\end{tikzpicture}%
}

% Arrow zwischen zwei Bildern
% Usage: \arrowImages{<length of arrow in cm>}{<left image>}{<right image>}
% Example: \arrowImages{1.3}
    %{\includegraphics[height=2.5cm]{5-Decorator/bilder/cpp1.png}}
    %{\includegraphics[height=4cm]{5-Decorator/bilder/realwelt1.png}}
\newcommand{\arrowImages}[3]{%
\begin{tikzpicture}
    % left image
    \node[anchor=east] at ([xshift=-0.2cm]0,0) {#2};
    \pause
    % arrow
    \draw[
        draw=Blue,
        line width=3mm,
        -{Triangle[length=6mm,width=6mm]}
    ]
    (0,0) -- (#1cm,0);
    \pause
    % right image
    \node[anchor=west] at ([xshift=0.2cm]#1cm,0) {#3};
\end{tikzpicture}%
}


